{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        { "cmd": "pnpm install --no-frozen-lockfile --ignore-scripts" }
      ]
    },
    "build": {
      "commands": [
        { "cmd": "pnpm --filter @workspace/api-server build" }
      ]
    }
  },
  "deploy": {
    "startCommand": "node artifacts/api-server/dist/index.mjs"
  }
}
